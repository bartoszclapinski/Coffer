<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Main;assembly=Coffer.Application"
        xmlns:dashboardVm="clr-namespace:Coffer.Application.ViewModels.Dashboard;assembly=Coffer.Application"
        xmlns:importVm="clr-namespace:Coffer.Application.ViewModels.Import;assembly=Coffer.Application"
        xmlns:txVm="clr-namespace:Coffer.Application.ViewModels.Transactions;assembly=Coffer.Application"
        xmlns:chatVm="clr-namespace:Coffer.Application.ViewModels.Chat;assembly=Coffer.Application"
        xmlns:alertsVm="clr-namespace:Coffer.Application.ViewModels.Alerts;assembly=Coffer.Application"
        xmlns:goalsVm="clr-namespace:Coffer.Application.ViewModels.Goals;assembly=Coffer.Application"
        xmlns:planningVm="clr-namespace:Coffer.Application.ViewModels.Planning;assembly=Coffer.Application"
        xmlns:spendingVm="clr-namespace:Coffer.Application.ViewModels.Spending;assembly=Coffer.Application"
        xmlns:budgetsVm="clr-namespace:Coffer.Application.ViewModels.Budgets;assembly=Coffer.Application"
        xmlns:forecastVm="clr-namespace:Coffer.Application.ViewModels.Forecast;assembly=Coffer.Application"
        xmlns:settingsVm="clr-namespace:Coffer.Application.ViewModels.Settings;assembly=Coffer.Application"
        xmlns:views="clr-namespace:Coffer.Desktop.Views"
        xmlns:m="clr-namespace:Coffer.Desktop.Markup"
        xmlns:l="clr-namespace:Coffer.Desktop.Localization"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="880"
        x:Class="Coffer.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="False"
        Title="Coffer"
        Width="1400" Height="880"
        MinWidth="1180" MinHeight="740"
        Background="{DynamicResource Coffer.Bg}"
        WindowStartupLocation="CenterScreen">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}" />
    </Window.KeyBindings>

    <Window.DataTemplates>
        <DataTemplate DataType="dashboardVm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="importVm:ImportViewModel">
            <views:ImportView />
        </DataTemplate>
        <DataTemplate DataType="txVm:TransactionsViewModel">
            <views:TransactionsView />
        </DataTemplate>
        <DataTemplate DataType="chatVm:ChatViewModel">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="alertsVm:AlertsViewModel">
            <views:AlertsView />
        </DataTemplate>
        <DataTemplate DataType="goalsVm:GoalsViewModel">
            <views:GoalsView />
        </DataTemplate>
        <DataTemplate DataType="planningVm:CashFlowPlanningViewModel">
            <views:CashFlowPlanningView />
        </DataTemplate>
        <DataTemplate DataType="planningVm:AffordabilityViewModel">
            <views:AffordabilityView />
        </DataTemplate>
        <DataTemplate DataType="spendingVm:SpendingExplorerViewModel">
            <views:SpendingExplorerView />
        </DataTemplate>
        <DataTemplate DataType="budgetsVm:BudgetsViewModel">
            <views:BudgetsView />
        </DataTemplate>
        <DataTemplate DataType="forecastVm:ForecastViewModel">
            <views:ForecastView />
        </DataTemplate>
        <DataTemplate DataType="settingsVm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <!-- ===================== Shell ===================== -->
        <Grid ColumnDefinitions="60,*">

            <!-- Icon rail -->
            <Border Grid.Column="0" Background="{DynamicResource Coffer.Panel2}"
                    BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0" Width="34" Height="34" CornerRadius="9"
                            Background="{DynamicResource Coffer.Accent}"
                            Margin="0,14,0,12" HorizontalAlignment="Center">
                        <TextBlock Text="C" Foreground="White" FontWeight="Bold" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding NavItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="rail" Classes.active="{Binding IsActive}"
                                            ToolTip.Tip="{Binding Title}"
                                            Content="{Binding Icon, Converter={x:Static m:PhosphorGlyphConverter.Instance}}"
                                            Command="{Binding $parent[ItemsControl].DataContext.NavigateCommand}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Classes="rail" Margin="0,12,0,14" HorizontalAlignment="Center"
                            Classes.active="{Binding SettingsItem.IsActive}"
                            ToolTip.Tip="{Binding SettingsItem.Title}"
                            Content="{Binding SettingsItem.Icon, Converter={x:Static m:PhosphorGlyphConverter.Instance}}"
                            Command="{Binding NavigateCommand}" CommandParameter="{Binding SettingsItem}" />
                </Grid>
            </Border>

            <!-- Main area -->
            <Grid Grid.Column="1" RowDefinitions="52,*">

                <!-- Top bar -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <Border Grid.ColumnSpan="2" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,0,0,1" />
                    <TextBlock Grid.Column="0" Classes="title" Text="{Binding ActiveTitle}"
                               VerticalAlignment="Center" Margin="22,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                Margin="0,0,22,0" VerticalAlignment="Center">
                        <!-- Search / command-palette affordance -->
                        <Button Command="{Binding OpenCommandPaletteCommand}" Width="250" Height="36"
                                Padding="10,0" CornerRadius="10" HorizontalContentAlignment="Stretch"
                                Background="{DynamicResource Coffer.Panel}"
                                BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" FontFamily="{DynamicResource Coffer.Icons}"
                                           Foreground="{DynamicResource Coffer.Mut}" VerticalAlignment="Center"
                                           Text="{m:PhosphorIcon magnifying-glass}" />
                                <TextBlock Grid.Column="1" Margin="8,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Coffer.Mut}"
                                           Text="{l:Localize TopBar.Search}" />
                                <Border Grid.Column="2" Background="{DynamicResource Coffer.Panel2}"
                                        CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="⌘K" FontSize="11" Foreground="{DynamicResource Coffer.Mut}" />
                                </Border>
                            </Grid>
                        </Button>

                        <Button Classes="topbar" Command="{Binding ToggleThemeCommand}"
                                ToolTip.Tip="{l:Localize Palette.SwitchTheme}"
                                Content="{Binding IsDarkTheme, Converter={x:Static m:ShellIconConverters.Theme}}" />
                        <Button Classes="topbar" Command="{Binding ToggleBalancesCommand}"
                                ToolTip.Tip="{l:Localize Palette.ToggleBalances}"
                                Content="{Binding HideBalances, Converter={x:Static m:ShellIconConverters.Privacy}}" />
                        <Button Classes="accent" Command="{Binding OpenCommandPaletteCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock FontFamily="{DynamicResource Coffer.Icons}" Text="{m:PhosphorIcon plus}" />
                                <TextBlock Text="{l:Localize TopBar.New}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Content -->
                <Border Grid.Row="1" Background="{DynamicResource Coffer.Bg}">
                    <ContentControl Content="{Binding CurrentPage}" />
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== Command palette overlay ===================== -->
        <Border Name="PaletteBackdrop" IsVisible="{Binding Palette.IsOpen}" Background="#99000000"
                PointerPressed="OnBackdropPressed">
            <Border Classes="panel" Padding="0" Width="580" MaxHeight="460"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    PointerPressed="OnPalettePressed">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="16,14">
                        <TextBlock Grid.Column="0" FontFamily="{DynamicResource Coffer.Icons}" FontSize="18"
                                   Foreground="{DynamicResource Coffer.Mut}" VerticalAlignment="Center"
                                   Text="{m:PhosphorIcon magnifying-glass}" />
                        <TextBox Name="PaletteInput" Grid.Column="1" Margin="10,0" BorderThickness="0"
                                 Background="Transparent" FontSize="16"
                                 Text="{Binding Palette.Query, Mode=TwoWay}"
                                 Watermark="{l:Localize Palette.Placeholder}"
                                 KeyDown="OnPaletteKeyDown" />
                        <Border Grid.Column="2" Background="{DynamicResource Coffer.Panel2}" CornerRadius="5"
                                Padding="6,2" VerticalAlignment="Center">
                            <TextBlock Text="esc" FontSize="11" Foreground="{DynamicResource Coffer.Mut}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,1,0,0">
                        <ListBox ItemsSource="{Binding Palette.Results}"
                                 SelectedIndex="{Binding Palette.SelectedIndex, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 Tapped="OnPaletteItemTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Height="30">
                                        <TextBlock Grid.Column="0" FontFamily="{DynamicResource Coffer.Icons}"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Coffer.Mut2}"
                                                   Text="{Binding Icon, Converter={x:Static m:PhosphorGlyphConverter.Instance}}" />
                                        <TextBlock Grid.Column="1" Margin="12,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Coffer.Tx}" Text="{Binding Title}" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10.5"
                                                   Foreground="{DynamicResource Coffer.Mut}" Text="{Binding Category}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <TextBlock Text="{l:Localize Palette.Hint}" FontSize="11"
                                   Foreground="{DynamicResource Coffer.Mut}" />
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Panel>
</Window>
