<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Forecast;assembly=Coffer.Application"
             xmlns:conv="clr-namespace:Coffer.Desktop.Converters"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="740"
             x:Class="Coffer.Desktop.Views.ForecastView"
             x:DataType="vm:ForecastViewModel"
             x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

            <TextBlock Text="{Binding MonthText}" Classes="label" />

            <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Forecast.Empty}" Classes="muted"
                       TextWrapping="Wrap" IsVisible="{Binding IsEmpty}" />

            <!-- Per-category forecast -->
            <Border Classes="panel" IsVisible="{Binding HasForecast}">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="label" Text="{l:Localize Forecast.Section.Categories}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="muted" Text="{l:Localize Forecast.TotalLabel}" VerticalAlignment="Center" />
                            <TextBlock Classes="money" FontSize="14" Text="{Binding TotalText}"
                                       Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                        </StackPanel>
                    </Grid>
                    <ItemsControl Name="ForecastList" ItemsSource="{Binding Forecasts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12" Margin="0,0,0,12">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5" Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                            <TextBlock Grid.Column="1" Text="{Binding CategoryName}"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Tx}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding TotalText}" Classes="money" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*,*,*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Forecast.Fixed}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding FixedText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Forecast.Variable}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding VariableText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Forecast.Suggested}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding SuggestedText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Forecast.CurrentLimit}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding CurrentLimitText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <Button Grid.Column="4" Classes="chip"
                                                    Content="{l:Localize Forecast.SetAsBudget}"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding CanAccept}"
                                                    Command="{Binding DataContext.AcceptSuggestionCommand, ElementName=ForecastList}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
