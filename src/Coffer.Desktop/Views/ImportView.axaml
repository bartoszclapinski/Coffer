<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Import;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.ImportView"
             x:DataType="vm:ImportViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Import.Title}"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="#1D1D1F" />
                <TextBlock Text="{l:Localize Import.Subtitle}"
                           TextWrapping="Wrap"
                           Foreground="#8E8E93" />
            </StackPanel>

            <!-- Account -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="{l:Localize Import.Account}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <ComboBox HorizontalAlignment="Stretch"
                              PlaceholderText="{l:Localize Import.Account.Placeholder}"
                              IsEnabled="{Binding !IsCreatingNewAccount}"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Text="{Binding BankCode}" Foreground="#8E8E93" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="{l:Localize Import.Account.CreateNew}"
                              IsChecked="{Binding IsCreatingNewAccount, Mode=TwoWay}" />

                    <StackPanel Spacing="10" IsVisible="{Binding IsCreatingNewAccount}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{l:Localize Import.Account.Name}" Foreground="#8E8E93" />
                            <TextBox Text="{Binding NewAccountName, Mode=TwoWay}"
                                     Watermark="{l:Localize Import.Account.NameWatermark}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{l:Localize Import.Account.Number}" Foreground="#8E8E93" />
                            <TextBox Text="{Binding NewAccountNumber, Mode=TwoWay}"
                                     Watermark="{l:Localize Import.Account.NumberWatermark}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{l:Localize Import.Account.Currency}" Foreground="#8E8E93" />
                                <TextBox Text="{Binding NewAccountCurrency, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{l:Localize Import.Account.Type}" Foreground="#8E8E93" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AccountTypes}"
                                          SelectedItem="{Binding NewAccountType, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- File -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="{l:Localize Import.File}" FontWeight="SemiBold" Foreground="#1D1D1F" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="{l:Localize Import.File.Browse}"
                                IsEnabled="{Binding !IsImporting}"
                                Command="{Binding BrowseCommand}" />
                        <TextBlock Text="{Binding PickedFileName}"
                                   VerticalAlignment="Center"
                                   Foreground="#1D1D1F"
                                   IsVisible="{Binding HasPickedFile}" />
                        <TextBlock Text="{l:Localize Import.File.None}"
                                   VerticalAlignment="Center"
                                   Foreground="#8E8E93"
                                   IsVisible="{Binding !HasPickedFile}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action + progress -->
            <StackPanel Spacing="12">
                <Button Content="{l:Localize Import.Action}"
                        MinWidth="140"
                        HorizontalAlignment="Left"
                        IsDefault="True"
                        Command="{Binding ImportCommand}" />

                <StackPanel Spacing="6" IsVisible="{Binding IsImporting}">
                    <TextBlock Text="{Binding StageLabel}" Foreground="#1D1D1F" />
                    <ProgressBar IsIndeterminate="True" Height="4" />
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#D14"
                           TextWrapping="Wrap"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- Summary -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20"
                    BorderBrush="#E5E5EA" BorderThickness="1"
                    IsVisible="{Binding HasSummary}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{l:Localize Import.Summary.Title}" FontWeight="SemiBold" Foreground="#1D1D1F" />
                    <TextBlock Text="{Binding SummaryAddedText}"
                               Foreground="#1D1D1F" />
                    <TextBlock Text="{Binding SummarySkippedText}"
                               Foreground="#1D1D1F" />
                    <TextBlock Text="{l:Localize Import.Summary.AlreadyImported}"
                               Foreground="#8E8E93"
                               IsVisible="{Binding SummaryAlreadyImported}" />
                    <ItemsControl ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#B26A00" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
