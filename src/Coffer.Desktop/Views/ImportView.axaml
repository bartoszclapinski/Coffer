<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Import;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.ImportView"
             x:DataType="vm:ImportViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Margin="22" Spacing="24" MaxWidth="640" HorizontalAlignment="Left">

            <!-- Account -->
            <Border Classes="panel">
                <StackPanel Spacing="12">
                    <TextBlock Text="{l:Localize Import.Account}" Classes="title" />

                    <ComboBox HorizontalAlignment="Stretch"
                              PlaceholderText="{l:Localize Import.Account.Placeholder}"
                              IsEnabled="{Binding !IsCreatingNewAccount}"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Text="{Binding BankCode}" Foreground="{DynamicResource Coffer.Mut}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="{l:Localize Import.Account.CreateNew}"
                              IsChecked="{Binding IsCreatingNewAccount, Mode=TwoWay}" />

                    <StackPanel Spacing="10" IsVisible="{Binding IsCreatingNewAccount}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{l:Localize Import.Account.Name}" Classes="muted" />
                            <TextBox Text="{Binding NewAccountName, Mode=TwoWay}"
                                     Watermark="{l:Localize Import.Account.NameWatermark}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{l:Localize Import.Account.Number}" Classes="muted" />
                            <TextBox Text="{Binding NewAccountNumber, Mode=TwoWay}"
                                     Watermark="{l:Localize Import.Account.NumberWatermark}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{l:Localize Import.Account.Currency}" Classes="muted" />
                                <TextBox Text="{Binding NewAccountCurrency, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{l:Localize Import.Account.Type}" Classes="muted" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AccountTypes}"
                                          SelectedItem="{Binding NewAccountType, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- File -->
            <Border Classes="panel">
                <StackPanel Spacing="12">
                    <TextBlock Text="{l:Localize Import.File}" Classes="title" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="{l:Localize Import.File.Browse}"
                                Classes="chip"
                                IsEnabled="{Binding !IsImporting}"
                                Command="{Binding BrowseCommand}" />
                        <TextBlock Text="{Binding PickedFileName}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding HasPickedFile}" />
                        <TextBlock Text="{l:Localize Import.File.None}"
                                   VerticalAlignment="Center"
                                   Classes="muted"
                                   IsVisible="{Binding !HasPickedFile}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action + progress -->
            <StackPanel Spacing="12">
                <Button Content="{l:Localize Import.Action}"
                        Classes="accent"
                        MinWidth="140"
                        HorizontalAlignment="Left"
                        IsDefault="True"
                        Command="{Binding ImportCommand}" />

                <StackPanel Spacing="6" IsVisible="{Binding IsImporting}">
                    <TextBlock Text="{Binding StageLabel}" />
                    <ProgressBar IsIndeterminate="True" Height="4" />
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Coffer.Neg}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- Summary -->
            <Border Classes="panel"
                    IsVisible="{Binding HasSummary}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{l:Localize Import.Summary.Title}" Classes="title" />
                    <TextBlock Text="{Binding SummaryAddedText}" />
                    <TextBlock Text="{Binding SummarySkippedText}" />
                    <TextBlock Text="{l:Localize Import.Summary.AlreadyImported}"
                               Classes="muted"
                               IsVisible="{Binding SummaryAlreadyImported}" />
                    <Border Background="{DynamicResource Coffer.Panel2}" CornerRadius="6" Padding="10"
                            IsVisible="{Binding AiFallbackUsed}">
                        <TextBlock Text="{l:Localize Import.Summary.AiFallback}"
                                   Foreground="{DynamicResource Coffer.Mut2}" TextWrapping="Wrap" />
                    </Border>
                    <Border Background="{DynamicResource Coffer.NegTint}" CornerRadius="6" Padding="10"
                            IsVisible="{Binding OwnerNameUnredacted}">
                        <TextBlock Text="{l:Localize Import.Summary.OwnerNameUnredacted}"
                                   Foreground="{DynamicResource Coffer.Neg}" TextWrapping="Wrap" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{DynamicResource Coffer.Neg}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
