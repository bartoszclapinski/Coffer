<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Dashboard;assembly=Coffer.Application"
             xmlns:conv="clr-namespace:Coffer.Desktop.Converters"
             xmlns:m="clr-namespace:Coffer.Desktop.Markup"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="820"
             x:Class="Coffer.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="16">

            <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Dashboard.Empty}" Classes="muted" Margin="0,40,0,0"
                       HorizontalAlignment="Center" IsVisible="{Binding IsEmpty}" />

            <!-- KPI strip: one panel, four cells divided by the border token -->
            <Border Classes="panel" Padding="0" IsVisible="{Binding HasData}">
                <Grid ColumnDefinitions="*,*,*,*">
                    <StackPanel Grid.Column="0" Spacing="6" Margin="18">
                        <TextBlock Classes="label" Text="{l:Localize Dashboard.Income}" />
                        <TextBlock Classes="money" FontSize="24"
                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} {1}">
                                    <Binding Path="Income" />
                                    <Binding Path="Currency" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="1,0,0,0">
                        <StackPanel Spacing="6" Margin="18">
                            <TextBlock Classes="label" Text="{l:Localize Dashboard.Spend}" />
                            <TextBlock Classes="money" FontSize="24"
                                       Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="Spend" />
                                        <Binding Path="Currency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="1,0,0,0">
                        <StackPanel Spacing="6" Margin="18">
                            <TextBlock Classes="label" Text="{l:Localize Dashboard.Net}" />
                            <TextBlock Classes="money" FontSize="24"
                                       Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}"
                                       Foreground="{Binding Net, Converter={x:Static conv:AmountToBrushConverter.Instance}}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="Net" />
                                        <Binding Path="Currency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="1,0,0,0">
                        <StackPanel Spacing="6" Margin="18">
                            <TextBlock Classes="label" Text="{l:Localize Dashboard.Transactions}" />
                            <TextBlock Classes="money" FontSize="24" Text="{Binding TransactionCount}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Trend area chart (last 30 days) -->
            <Border Classes="panel" IsVisible="{Binding HasData}">
                <StackPanel Spacing="10">
                    <TextBlock Classes="label" Text="{l:Localize Dashboard.Spend30}" />
                    <lvc:CartesianChart Height="180" Series="{Binding DailySpendSeries}" XAxes="{Binding DailyXAxes}" />
                </StackPanel>
            </Border>

            <!-- Recent activity + allocation -->
            <Grid ColumnDefinitions="1.6*,16,*" IsVisible="{Binding HasData}">
                <Border Grid.Column="0" Classes="panel">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="label" Text="{l:Localize Dashboard.Recent}" />
                        <ItemsControl ItemsSource="{Binding RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="66,Auto,*,Auto" Margin="0,7">
                                        <TextBlock Grid.Column="0" Classes="muted" VerticalAlignment="Center"
                                                   Text="{Binding Date, StringFormat='{}{0:dd.MM}'}" />
                                        <Ellipse Grid.Column="1" Width="10" Height="10" Margin="0,0,12,0"
                                                 VerticalAlignment="Center"
                                                 IsVisible="{Binding CategoryColor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Fill="{Binding CategoryColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Coffer.Tx}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Classes="muted" FontSize="11" Text="{Binding CategoryName}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Classes="money" VerticalAlignment="Center"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}"
                                                   Foreground="{Binding Amount, Converter={x:Static conv:AmountToBrushConverter.Instance}}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:N2} {1}">
                                                    <Binding Path="Amount" />
                                                    <Binding Path="Currency" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="label" Text="{l:Localize Dashboard.Categories}" />
                        <lvc:PieChart Height="170" Series="{Binding CategorySeries}" />
                        <ItemsControl ItemsSource="{Binding TopCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,3">
                                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                        <TextBlock Grid.Column="1" Classes="muted" VerticalAlignment="Center"
                                                   Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Classes="money" FontSize="12" VerticalAlignment="Center"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}"
                                                   Text="{Binding Total, StringFormat='{}{0:N0}'}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 12-month spend -->
            <Border Classes="panel" IsVisible="{Binding HasData}">
                <StackPanel Spacing="10">
                    <TextBlock Classes="label" Text="{l:Localize Dashboard.Spend12}" />
                    <lvc:CartesianChart Height="170" Series="{Binding MonthlySpendSeries}" XAxes="{Binding MonthlyXAxes}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
