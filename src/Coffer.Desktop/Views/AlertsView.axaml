<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Alerts;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.AlertsView"
             x:DataType="vm:AlertsViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <Grid Margin="22" RowDefinitions="Auto,Auto,Auto">
            <ProgressBar Grid.Row="0" IsIndeterminate="True" Height="4"
                         VerticalAlignment="Bottom"
                         IsVisible="{Binding IsLoading}" />

            <TextBlock Grid.Row="1"
                       Margin="0,20,0,0"
                       Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Grid.Row="1"
                       Margin="0,40,0,0"
                       Classes="muted"
                       Text="{l:Localize Alerts.Empty}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding IsEmpty}" />

            <ItemsControl Grid.Row="2" Margin="0,24,0,0"
                          ItemsSource="{Binding Alerts}"
                          IsVisible="{Binding HasAlerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AlertRowViewModel">
                        <Border Classes="panel" Padding="20,16" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="title" Text="{Binding Title}" />
                                    <TextBlock Classes="muted" TextWrapping="Wrap" Text="{Binding Description}" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Classes="muted" Text="{Binding PeriodText}" />
                                        <TextBlock Classes="money"
                                                   FontSize="12"
                                                   Text="{Binding AmountText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}"
                                                   IsVisible="{Binding HasAmount}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Button Classes="chip"
                                            Content="{l:Localize Alerts.Acknowledge}"
                                            Command="{Binding AcknowledgeCommand}"
                                            IsEnabled="{Binding !IsBusy}" />
                                    <Button Classes="chip"
                                            Content="{l:Localize Alerts.Dismiss}"
                                            Command="{Binding DismissCommand}"
                                            IsEnabled="{Binding !IsBusy}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
