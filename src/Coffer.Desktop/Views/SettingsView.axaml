<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Settings;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24" MaxWidth="560" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Settings.Title}"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="#1D1D1F" />
                <TextBlock Text="{l:Localize Settings.Subtitle}"
                           Foreground="#8E8E93" />
            </StackPanel>

            <!-- Language -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l:Localize Settings.Language.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.Language.Label}" FontSize="12" Foreground="#8E8E93" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding DisplayName}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI provider + model -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l:Localize Settings.Ai.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.Ai.Provider}" FontSize="12" Foreground="#8E8E93" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.Ai.Model}" FontSize="12" Foreground="#8E8E93" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Models}"
                                  SelectedItem="{Binding CategorizationModel, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Claude API key -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Settings.ApiKey.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        <TextBlock Foreground="#8E8E93" FontSize="12" TextWrapping="Wrap"
                                   Text="{l:Localize Settings.ApiKey.Hint}" />
                    </StackPanel>

                    <Border Background="#F0FDF4" CornerRadius="6" Padding="10"
                            IsVisible="{Binding HasApiKey}">
                        <TextBlock Text="{l:Localize Settings.ApiKey.Present}" Foreground="#15803D" FontSize="12" />
                    </Border>
                    <Border Background="#FEF2F2" CornerRadius="6" Padding="10"
                            IsVisible="{Binding !HasApiKey}">
                        <TextBlock Text="{l:Localize Settings.ApiKey.Absent}" Foreground="#B91C1C" FontSize="12" />
                    </Border>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.ApiKey.New}" FontSize="12" Foreground="#8E8E93" />
                        <TextBox PasswordChar="•"
                                 Text="{Binding ApiKeyInput, Mode=TwoWay}"
                                 Watermark="sk-ant-…" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{l:Localize Settings.ApiKey.Save}"
                                Command="{Binding SaveApiKeyCommand}" />
                        <Button Content="{l:Localize Settings.ApiKey.Clear}"
                                Command="{Binding ClearApiKeyCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Budget -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l:Localize Settings.Budget.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.Budget.Cap}" FontSize="12" Foreground="#8E8E93" />
                        <NumericUpDown Minimum="0"
                                       Increment="5"
                                       FormatString="0.00"
                                       Value="{Binding MonthlyCapPln, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="{l:Localize Settings.Budget.Spent}" FontSize="12" Foreground="#8E8E93" />
                        <TextBlock FontSize="18" Foreground="#1D1D1F"
                                   Text="{Binding CurrentMonthSpendPln, StringFormat='{}{0:0.00} PLN'}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Planning: safety floor -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l:Localize Settings.Planning.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.Planning.SafetyFloor}" FontSize="12" Foreground="#8E8E93" />
                        <NumericUpDown Minimum="0"
                                       Increment="100"
                                       FormatString="0.00"
                                       Value="{Binding SafetyFloorPln, Mode=TwoWay}" />
                        <TextBlock Text="{l:Localize Settings.Planning.SafetyFloorHint}"
                                   FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Account balance anchors -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Settings.Anchor.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        <TextBlock Text="{l:Localize Settings.Anchor.Hint}"
                                   FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Text="{l:Localize Settings.Anchor.NoAccounts}"
                               FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap"
                               IsVisible="{Binding !HasAccounts}" />

                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AccountAnchorRowViewModel">
                                <Border Background="#F5F5F7" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontWeight="SemiBold" Foreground="#1D1D1F"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,2"
                                                    Background="#34C759" VerticalAlignment="Center"
                                                    IsVisible="{Binding HasAnchor}">
                                                <TextBlock Text="{l:Localize Settings.Anchor.Set}"
                                                           FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            </Border>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*">
                                            <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,6,0">
                                                <TextBlock Text="{l:Localize Settings.Anchor.Balance}"
                                                           FontSize="12" Foreground="#8E8E93" />
                                                <NumericUpDown Increment="100" FormatString="0.00"
                                                               Value="{Binding AnchorBalance}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2" Margin="6,0,0,0">
                                                <TextBlock Text="{l:Localize Settings.Anchor.Date}"
                                                           FontSize="12" Foreground="#8E8E93" />
                                                <DatePicker SelectedDate="{Binding AnchorDate}" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="{l:Localize Settings.Anchor.Save}"
                                                    IsEnabled="{Binding !IsBusy}"
                                                    Command="{Binding SaveAnchorCommand}" />
                                            <Button Content="{l:Localize Settings.Anchor.Clear}"
                                                    IsEnabled="{Binding !IsBusy}"
                                                    Command="{Binding ClearAnchorCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- AI fallback parsing -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l:Localize Settings.AiFallback.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <CheckBox Content="{l:Localize Settings.AiFallback.Toggle}"
                              IsChecked="{Binding AiFallbackParsingEnabled, Mode=TwoWay}" />
                    <TextBlock Text="{l:Localize Settings.AiFallback.Consent}"
                               FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Settings.AiFallback.OwnerName}" FontSize="12" Foreground="#8E8E93" />
                        <TextBox Text="{Binding OwnerIdentityNames, Mode=TwoWay}" />
                        <TextBlock Text="{l:Localize Settings.AiFallback.OwnerNameHint}"
                                   FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Backup & Recovery -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Settings.Backup.Section}" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        <TextBlock Text="{l:Localize Settings.Backup.Hint}"
                                   FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{l:Localize Settings.Backup.LastSnapshot}" FontSize="12" Foreground="#8E8E93" />
                            <TextBlock Text="{Binding LastDailySnapshotText}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{l:Localize Settings.Backup.Count}" FontSize="12" Foreground="#8E8E93" />
                            <TextBlock Text="{Binding DailyBackupCountText}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{l:Localize Settings.Backup.Now}"
                                IsEnabled="{Binding !IsBusy}"
                                Command="{Binding BackupNowCommand}" />
                        <Button Content="{l:Localize Settings.Backup.Export}"
                                IsEnabled="{Binding !IsBusy}"
                                Command="{Binding ExportArchiveCommand}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{l:Localize Settings.Restore.Button}"
                                IsEnabled="{Binding !IsBusy}"
                                Command="{Binding RestoreFromSnapshotCommand}" />
                    </StackPanel>

                    <TextBlock Text="{l:Localize Settings.Restore.Note}"
                               FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />

                    <TextBlock Text="{l:Localize Settings.SeedRecovery.Section}"
                               FontWeight="SemiBold" Foreground="#1D1D1F" Margin="0,8,0,0" />
                    <TextBlock Text="{l:Localize Settings.SeedRecovery.EnabledState}"
                               FontSize="13" Foreground="#34C759"
                               IsVisible="{Binding SeedRecoveryEnabled}" />
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding !SeedRecoveryEnabled}">
                        <Button Content="{l:Localize Settings.SeedRecovery.Enable}"
                                IsEnabled="{Binding !IsBusy}"
                                Command="{Binding EnableSeedRecoveryCommand}" />
                    </StackPanel>
                    <TextBlock Text="{l:Localize Settings.SeedRecovery.Hint}"
                               FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="{l:Localize Settings.Save}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding !IsBusy}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="#8E8E93"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
