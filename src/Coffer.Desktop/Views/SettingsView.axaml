<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Settings;assembly=Coffer.Application"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24" MaxWidth="560" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock Text="Ustawienia"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="#1D1D1F" />
                <TextBlock Text="Konfiguracja AI i budżetu miesięcznego."
                           Foreground="#8E8E93" />
            </StackPanel>

            <!-- AI provider + model -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Dostawca AI" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Dostawca" FontSize="12" Foreground="#8E8E93" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Model kategoryzacji" FontSize="12" Foreground="#8E8E93" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Models}"
                                  SelectedItem="{Binding CategorizationModel, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Claude API key -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Klucz API (Claude)" FontWeight="SemiBold" Foreground="#1D1D1F" />
                        <TextBlock Foreground="#8E8E93" FontSize="12" TextWrapping="Wrap"
                                   Text="Klucz jest szyfrowany lokalnie (DPAPI) i nigdy nie jest zapisywany jawnie ani logowany." />
                    </StackPanel>

                    <Border Background="#F0FDF4" CornerRadius="6" Padding="10"
                            IsVisible="{Binding HasApiKey}">
                        <TextBlock Text="Klucz API jest zapisany." Foreground="#15803D" FontSize="12" />
                    </Border>
                    <Border Background="#FEF2F2" CornerRadius="6" Padding="10"
                            IsVisible="{Binding !HasApiKey}">
                        <TextBlock Text="Brak zapisanego klucza API." Foreground="#B91C1C" FontSize="12" />
                    </Border>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Nowy klucz" FontSize="12" Foreground="#8E8E93" />
                        <TextBox PasswordChar="•"
                                 Text="{Binding ApiKeyInput, Mode=TwoWay}"
                                 Watermark="sk-ant-…" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Zapisz klucz"
                                Command="{Binding SaveApiKeyCommand}" />
                        <Button Content="Usuń klucz"
                                Command="{Binding ClearApiKeyCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Budget -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Budżet miesięczny" FontWeight="SemiBold" Foreground="#1D1D1F" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Limit miesięczny (PLN)" FontSize="12" Foreground="#8E8E93" />
                        <NumericUpDown Minimum="0"
                                       Increment="5"
                                       FormatString="0.00"
                                       Value="{Binding MonthlyCapPln, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Wydano w tym miesiącu" FontSize="12" Foreground="#8E8E93" />
                        <TextBlock FontSize="18" Foreground="#1D1D1F"
                                   Text="{Binding CurrentMonthSpendPln, StringFormat='{}{0:0.00} PLN'}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Zapisz ustawienia"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding !IsBusy}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="#8E8E93"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
