<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Coffer.Desktop.Views.Setup.WelcomeStepView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="{l:Localize Setup.Welcome.Title}"
                       FontSize="28"
                       FontWeight="Light" />
            <TextBlock TextWrapping="Wrap"
                       Text="{l:Localize Setup.Welcome.Intro}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="12" VerticalAlignment="Center">
            <TextBlock TextWrapping="Wrap"
                       Text="{l:Localize Setup.Welcome.StepsHeader}" />
            <TextBlock TextWrapping="Wrap"
                       Margin="16,0,0,0"
                       Text="{l:Localize Setup.Welcome.Step1}" />
            <TextBlock TextWrapping="Wrap"
                       Margin="16,0,0,0"
                       Text="{l:Localize Setup.Welcome.Step2}" />
            <TextBlock TextWrapping="Wrap"
                       Margin="16,0,0,0"
                       Text="{l:Localize Setup.Welcome.Step3}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="{l:Localize Setup.Next}"
                    MinWidth="120"
                    Command="{Binding $parent[Window].DataContext.NextCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
