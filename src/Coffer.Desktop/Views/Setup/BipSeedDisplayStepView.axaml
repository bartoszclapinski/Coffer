<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Coffer.Desktop.Views.Setup.BipSeedDisplayStepView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="{l:Localize Setup.SeedDisplay.Title}"
                       FontSize="22"
                       FontWeight="Light" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#E07B00"
                       Text="{l:Localize Setup.SeedDisplay.Warning}" />
        </StackPanel>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Words}"
                      Margin="0,16,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" Rows="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#555"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="4"
                            Padding="12,8">
                        <TextBlock Text="{Binding}"
                                   FontFamily="Consolas, Menlo, monospace"
                                   FontSize="16" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="{l:Localize Setup.Back}"
                    MinWidth="120"
                    Command="{Binding $parent[Window].DataContext.BackCommand}" />
            <Button Content="{l:Localize Setup.SeedDisplay.Saved}"
                    MinWidth="160"
                    Command="{Binding $parent[Window].DataContext.NextCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
