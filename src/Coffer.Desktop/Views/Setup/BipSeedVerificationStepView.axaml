<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Coffer.Desktop.Views.Setup.BipSeedVerificationStepView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="{l:Localize Setup.Verification.Title}"
                       FontSize="22"
                       FontWeight="Light" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#999"
                       Text="{l:Localize Setup.Verification.Hint}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="16" Margin="0,24,0,0">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Setup.Verification.Word3}" />
                <TextBox Text="{Binding Word3, Mode=TwoWay}"
                         FontFamily="Consolas, Menlo, monospace" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Setup.Verification.Word7}" />
                <TextBox Text="{Binding Word7, Mode=TwoWay}"
                         FontFamily="Consolas, Menlo, monospace" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="{l:Localize Setup.Back}"
                    MinWidth="120"
                    Command="{Binding $parent[Window].DataContext.BackCommand}" />
            <Button Content="{l:Localize Setup.Next}"
                    MinWidth="120"
                    IsEnabled="{Binding IsValid}"
                    Command="{Binding $parent[Window].DataContext.NextCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
