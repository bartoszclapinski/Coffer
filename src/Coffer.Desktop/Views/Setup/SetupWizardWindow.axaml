<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Setup;assembly=Coffer.Application"
        xmlns:views="clr-namespace:Coffer.Desktop.Views.Setup"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="520"
        x:Class="Coffer.Desktop.Views.Setup.SetupWizardWindow"
        x:DataType="vm:SetupWizardViewModel"
        Title="Coffer — konfiguracja sejfu"
        Width="640" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    <Window.DataTemplates>
        <DataTemplate DataType="vm:WelcomeStepViewModel">
            <views:WelcomeStepView />
        </DataTemplate>
        <DataTemplate DataType="vm:MasterPasswordStepViewModel">
            <views:MasterPasswordStepView />
        </DataTemplate>
        <DataTemplate DataType="vm:BipSeedDisplayStepViewModel">
            <views:BipSeedDisplayStepView />
        </DataTemplate>
        <DataTemplate DataType="vm:BipSeedVerificationStepViewModel">
            <views:BipSeedVerificationStepView />
        </DataTemplate>
        <DataTemplate DataType="vm:ConfirmStepViewModel">
            <views:ConfirmStepView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <TextBlock Grid.Row="0"
                   Text="Coffer — konfiguracja sejfu"
                   FontSize="22"
                   FontWeight="Light"
                   Margin="0,0,0,16" />
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentStepViewModel}" />
    </Grid>
</Window>
