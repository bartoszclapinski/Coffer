<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Planning;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.AffordabilityView"
             x:DataType="vm:AffordabilityViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E5EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20,16" />
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>
        <Style Selector="TextBlock.metricLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#8E8E93" />
        </Style>
        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20" MaxWidth="620" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Affordability.Title}"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="#1D1D1F" />
                <TextBlock Text="{l:Localize Affordability.Subtitle}"
                           Foreground="#8E8E93"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Input -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Account}" Classes="metricLabel" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Amount}" Classes="metricLabel" />
                        <NumericUpDown Minimum="0"
                                       Increment="50"
                                       FormatString="N2"
                                       Value="{Binding Amount, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Date}" Classes="metricLabel" />
                        <DatePicker SelectedDate="{Binding SpendDate, Mode=TwoWay}" />
                    </StackPanel>

                    <Button Content="{l:Localize Affordability.Check}"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding !IsLoading}"
                            Command="{Binding CheckCommand}" />
                </StackPanel>
            </Border>

            <ProgressBar IsIndeterminate="True" Height="4"
                         IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#D14"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Affordability.Empty}"
                       Foreground="#8E8E93"
                       TextWrapping="Wrap"
                       IsVisible="{Binding !HasResult}" />

            <!-- Result -->
            <StackPanel Spacing="16" IsVisible="{Binding HasResult}">
                <!-- Verdict banner -->
                <Border CornerRadius="10" Padding="20,16"
                        Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                        IsVisible="{Binding CanAfford}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerdictText}" FontSize="18" FontWeight="SemiBold" Foreground="#15803D" />
                        <TextBlock Foreground="#15803D" TextWrapping="Wrap"
                                   Text="{Binding AmountText, StringFormat={}{0}}" />
                    </StackPanel>
                </Border>
                <Border CornerRadius="10" Padding="20,16"
                        Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                        IsVisible="{Binding !CanAfford}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerdictText}" FontSize="18" FontWeight="SemiBold" Foreground="#B91C1C" />
                        <TextBlock Foreground="#B91C1C" TextWrapping="Wrap"
                                   Text="{Binding AmountText, StringFormat={}{0}}" />
                    </StackPanel>
                </Border>

                <!-- Relative / uncertain warnings -->
                <Border Classes="card" Background="#FFF7ED" BorderBrush="#FED7AA"
                        IsVisible="{Binding IsRelative}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Affordability.Relative.Title}"
                                   FontWeight="SemiBold" Foreground="#C2410C" TextWrapping="Wrap" />
                        <TextBlock Text="{l:Localize Affordability.Relative.Hint}"
                                   Foreground="#C2410C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Classes="card" Background="#FDECEA" BorderBrush="#F5C2BC"
                        IsVisible="{Binding IsUncertain}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Affordability.Uncertain.Title}"
                                   FontWeight="SemiBold" Foreground="#B42318" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding UncertaintyText}"
                                   Foreground="#B42318" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Metrics -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Classes="sectionTitle" Text="{l:Localize Affordability.Section.Details}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.Opening}" />
                                <TextBlock Classes="metricValue" Text="{Binding OpeningBalanceText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.SafetyFloor}" />
                                <TextBlock Classes="metricValue" Text="{Binding SafetyFloorText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.Lowest}" />
                                <TextBlock Classes="metricValue" Text="{Binding LowestBalanceText}" />
                                <TextBlock Classes="metricLabel" Text="{Binding LowestBalanceDateText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.Headroom}" />
                                <TextBlock Classes="metricValue" Text="{Binding HeadroomText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.DailyBurn}" />
                                <TextBlock Classes="metricValue" Text="{Binding DailyBurnText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                                <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Summary.NextInflow}" />
                                <TextBlock Classes="metricValue" Text="{Binding NextInflowText}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="2" IsVisible="{Binding HasDriver}">
                            <TextBlock Classes="metricLabel" Text="{l:Localize Affordability.Driver.Label}" />
                            <TextBlock Classes="metricValue" Text="{Binding DriverText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
