<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Planning;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.AffordabilityView"
             x:DataType="vm:AffordabilityViewModel"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Margin="22" Spacing="20" MaxWidth="620" HorizontalAlignment="Left">
            <!-- Input -->
            <Border Classes="panel">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Account}" Classes="muted" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Amount}" Classes="muted" />
                        <NumericUpDown Minimum="0"
                                       Increment="50"
                                       FormatString="N2"
                                       Value="{Binding Amount, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{l:Localize Affordability.Date}" Classes="muted" />
                        <DatePicker SelectedDate="{Binding SpendDate, Mode=TwoWay}" />
                    </StackPanel>

                    <Button Content="{l:Localize Affordability.Check}"
                            Classes="accent"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding !IsLoading}"
                            Command="{Binding CheckCommand}" />
                </StackPanel>
            </Border>

            <ProgressBar Classes="bar" IsIndeterminate="True" Height="4"
                         IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Affordability.Empty}"
                       Classes="muted"
                       TextWrapping="Wrap"
                       IsVisible="{Binding !HasResult}" />

            <!-- Result -->
            <StackPanel Spacing="16" IsVisible="{Binding HasResult}">
                <!-- Verdict banner -->
                <Border Classes="panel" Background="{DynamicResource Coffer.PosTint}"
                        BorderBrush="{DynamicResource Coffer.Pos}"
                        IsVisible="{Binding CanAfford}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerdictText}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Pos}" />
                        <TextBlock Foreground="{DynamicResource Coffer.Pos}" TextWrapping="Wrap"
                                   Text="{Binding AmountText, StringFormat={}{0}}" />
                    </StackPanel>
                </Border>
                <Border Classes="panel" Background="{DynamicResource Coffer.NegTint}"
                        BorderBrush="{DynamicResource Coffer.Neg}"
                        IsVisible="{Binding !CanAfford}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerdictText}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Neg}" />
                        <TextBlock Foreground="{DynamicResource Coffer.Neg}" TextWrapping="Wrap"
                                   Text="{Binding AmountText, StringFormat={}{0}}" />
                    </StackPanel>
                </Border>

                <!-- Relative / uncertain warnings -->
                <Border Classes="panel"
                        IsVisible="{Binding IsRelative}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Affordability.Relative.Title}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Neg}" TextWrapping="Wrap" />
                        <TextBlock Text="{l:Localize Affordability.Relative.Hint}"
                                   Classes="muted" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Classes="panel"
                        IsVisible="{Binding IsUncertain}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{l:Localize Affordability.Uncertain.Title}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Neg}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding UncertaintyText}"
                                   Classes="muted" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Metrics -->
                <Border Classes="panel">
                    <StackPanel Spacing="16">
                        <TextBlock Classes="label" Text="{l:Localize Affordability.Section.Details}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.Opening}" />
                                <TextBlock Classes="money" Text="{Binding OpeningBalanceText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.SafetyFloor}" />
                                <TextBlock Classes="money" Text="{Binding SafetyFloorText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.Lowest}" />
                                <TextBlock Classes="money" Text="{Binding LowestBalanceText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                <TextBlock Classes="muted" Text="{Binding LowestBalanceDateText}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,0,0,12">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.Headroom}" />
                                <TextBlock Classes="money" Text="{Binding HeadroomText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.DailyBurn}" />
                                <TextBlock Classes="money" Text="{Binding DailyBurnText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                                <TextBlock Classes="muted" Text="{l:Localize Affordability.Summary.NextInflow}" />
                                <TextBlock Classes="money" Text="{Binding NextInflowText}"
                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="2" IsVisible="{Binding HasDriver}">
                            <TextBlock Classes="muted" Text="{l:Localize Affordability.Driver.Label}" />
                            <TextBlock Classes="money" Text="{Binding DriverText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
