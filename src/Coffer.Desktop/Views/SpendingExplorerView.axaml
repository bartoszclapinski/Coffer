<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Spending;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="740"
             x:Class="Coffer.Desktop.Views.SpendingExplorerView"
             x:DataType="vm:SpendingExplorerViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="Button.row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.row:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Coffer.Hover}" />
        </Style>
        <Style Selector="TextBlock.rowLabel">
            <Setter Property="Foreground" Value="{DynamicResource Coffer.Tx}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

            <!-- Controls -->
            <Border Classes="panel">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{l:Localize Spending.Account}" Classes="label" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                      DisplayMemberBinding="{Binding Label}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="{l:Localize Spending.Period}" Classes="label" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Presets}"
                                      SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                      DisplayMemberBinding="{Binding Label}" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*" IsVisible="{Binding IsCustomWindow}">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{l:Localize Spending.CustomFrom}" Classes="label" />
                            <DatePicker SelectedDate="{Binding CustomFrom, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="{l:Localize Spending.CustomTo}" Classes="label" />
                            <DatePicker SelectedDate="{Binding CustomTo, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <Button Classes="accent" Content="{l:Localize Spending.Apply}"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding !IsLoading}"
                            Command="{Binding ApplyWindowCommand}" />
                </StackPanel>
            </Border>

            <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Breadcrumb + total -->
            <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding !IsLoading}">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="chip" Content="{l:Localize Spending.Back}"
                            IsVisible="{Binding CanGoBack}"
                            Command="{Binding BackCommand}" />
                    <TextBlock Text="{Binding WindowText}" Classes="muted" VerticalAlignment="Center" />
                    <TextBlock Text="›" Foreground="{DynamicResource Coffer.Mut}" VerticalAlignment="Center"
                               IsVisible="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <TextBlock Text="{Binding SelectedCategory.Label}" Classes="muted" VerticalAlignment="Center"
                               IsVisible="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <TextBlock Text="›" Foreground="{DynamicResource Coffer.Mut}" VerticalAlignment="Center"
                               IsVisible="{Binding SelectedMerchant, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <TextBlock Text="{Binding SelectedMerchant.Label}" Classes="muted" VerticalAlignment="Center"
                               IsVisible="{Binding SelectedMerchant, Converter={x:Static ObjectConverters.IsNotNull}}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{l:Localize Spending.Total}" Classes="muted" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalText}" Classes="money" VerticalAlignment="Center"
                               Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="{l:Localize Spending.Empty}" Classes="muted"
                       TextWrapping="Wrap" IsVisible="{Binding IsEmpty}" />

            <!-- Categories -->
            <Border Classes="panel" IsVisible="{Binding IsCategoriesLevel}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="label" Text="{l:Localize Spending.Section.Categories}" />
                    <ItemsControl Name="CategoriesList" ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="row"
                                        Command="{Binding DataContext.SelectCategoryCommand, ElementName=CategoriesList}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="*,140,110,54">
                                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="{Binding Label}" />
                                        <ProgressBar Grid.Column="1" Classes="bar" Minimum="0" Maximum="100"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"
                                                     Value="{Binding SharePercent}" />
                                        <TextBlock Grid.Column="2" Classes="money" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Text="{Binding TotalText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                        <TextBlock Grid.Column="3" Classes="muted" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Text="{Binding ShareText}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Merchants -->
            <Border Classes="panel" IsVisible="{Binding IsMerchantsLevel}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="label" Text="{l:Localize Spending.Section.Merchants}" />
                    <ItemsControl Name="MerchantsList" ItemsSource="{Binding Merchants}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="row"
                                        Command="{Binding DataContext.SelectMerchantCommand, ElementName=MerchantsList}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="*,140,110,54">
                                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="{Binding Label}" />
                                        <ProgressBar Grid.Column="1" Classes="bar" Minimum="0" Maximum="100"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"
                                                     Value="{Binding SharePercent}" />
                                        <TextBlock Grid.Column="2" Classes="money" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Text="{Binding TotalText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                        <TextBlock Grid.Column="3" Classes="muted" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Text="{Binding ShareText}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Transactions -->
            <Border Classes="panel" IsVisible="{Binding IsTransactionsLevel}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="label" Text="{l:Localize Spending.Section.Transactions}" />
                    <ItemsControl ItemsSource="{Binding Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="100,*,120" Margin="12,8">
                                    <TextBlock Grid.Column="0" Classes="muted" VerticalAlignment="Center"
                                               Text="{Binding DateText}" />
                                    <TextBlock Grid.Column="1" Classes="rowLabel" Text="{Binding Title}" />
                                    <TextBlock Grid.Column="2" Classes="money" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Text="{Binding AmountText}"
                                               Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
