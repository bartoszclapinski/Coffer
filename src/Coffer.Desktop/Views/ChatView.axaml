<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Chat;assembly=Coffer.Application"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <!-- Chat bubbles: user speaks in the accent, the assistant on a panel surface. -->
        <Style Selector="Border.userBubble">
            <Setter Property="Background" Value="{DynamicResource Coffer.Accent}" />
            <Setter Property="CornerRadius" Value="12,12,2,12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MaxWidth" Value="460" />
        </Style>
        <Style Selector="Border.assistantBubble">
            <Setter Property="Background" Value="{DynamicResource Coffer.Panel}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Coffer.Bd}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12,12,12,2" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MaxWidth" Value="460" />
        </Style>
        <Style Selector="Button.suggestion">
            <Setter Property="Background" Value="{DynamicResource Coffer.Panel}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Coffer.Bd}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource Coffer.Mut2}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.suggestion:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Coffer.Hover}" />
        </Style>
        <Style Selector="Button.trace">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Coffer.Accent}" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="22" RowDefinitions="*,Auto,Auto">
        <!-- Transcript -->
        <ScrollViewer Grid.Row="0">
            <Grid>
                <!-- Empty state: suggested prompts -->
                <StackPanel IsVisible="{Binding IsEmpty}" Spacing="14" Margin="0,24,0,0"
                            HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="520">
                    <TextBlock Text="{l:Localize Chat.EmptyPrompt}"
                               FontSize="16"
                               Foreground="{DynamicResource Coffer.Tx}"
                               HorizontalAlignment="Center" />
                    <ItemsControl ItemsSource="{Binding SuggestedPrompts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="suggestion"
                                        Margin="4"
                                        Content="{Binding}"
                                        Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).UseSuggestionCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Messages -->
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <!-- User -->
                                <Border Classes="userBubble"
                                        HorizontalAlignment="Right"
                                        IsVisible="{Binding IsUser}">
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Coffer.OnAccent}" />
                                </Border>

                                <!-- Assistant -->
                                <StackPanel HorizontalAlignment="Left"
                                            Spacing="6"
                                            IsVisible="{Binding IsAssistant}">
                                    <Border Classes="assistantBubble">
                                        <TextBlock Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource Coffer.Tx}" />
                                    </Border>
                                    <StackPanel Spacing="4" IsVisible="{Binding HasToolTraces}">
                                        <Button Classes="trace"
                                                Content="{l:Localize Chat.ShowTools}"
                                                Command="{Binding ToggleToolTraceCommand}" />
                                        <Border Background="{DynamicResource Coffer.Panel2}"
                                                CornerRadius="8"
                                                Padding="12,8"
                                                IsVisible="{Binding IsToolTraceExpanded}">
                                            <ItemsControl ItemsSource="{Binding ToolTraceLines}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontFamily="Consolas, monospace"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Coffer.Mut2}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Status banners -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,12,0,0">
            <ProgressBar Classes="bar" IsIndeterminate="True" Height="4"
                         IsVisible="{Binding IsBusy}" />
            <Border Background="{DynamicResource Coffer.NegTint}" CornerRadius="8" Padding="14,10"
                    IsVisible="{Binding MissingApiKey}">
                <TextBlock Text="{l:Localize Chat.MissingApiKey}"
                           Foreground="{DynamicResource Coffer.Neg}"
                           TextWrapping="Wrap" />
            </Border>
            <Border Background="{DynamicResource Coffer.NegTint}" CornerRadius="8" Padding="14,10"
                    IsVisible="{Binding BudgetExceeded}">
                <TextBlock Text="{l:Localize Chat.BudgetExceeded}"
                           Foreground="{DynamicResource Coffer.Neg}"
                           TextWrapping="Wrap" />
            </Border>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- Input -->
        <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="*,12,Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding InputText}"
                     Watermark="{l:Localize Chat.InputWatermark}"
                     AcceptsReturn="False"
                     IsEnabled="{Binding !IsBusy}">
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding SendCommand}" />
                </TextBox.KeyBindings>
            </TextBox>
            <Button Grid.Column="2"
                    Classes="accent"
                    Content="{l:Localize Chat.Send}"
                    Padding="20,10"
                    Command="{Binding SendCommand}" />
        </Grid>
    </Grid>
</UserControl>
