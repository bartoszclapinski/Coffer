<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Budgets;assembly=Coffer.Application"
             xmlns:conv="clr-namespace:Coffer.Desktop.Converters"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="740"
             x:Class="Coffer.Desktop.Views.BudgetsView"
             x:DataType="vm:BudgetsViewModel"
             x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

            <TextBlock Text="{Binding MonthText}" Classes="label" />

            <!-- Add / edit a limit -->
            <Border Classes="panel">
                <StackPanel Spacing="16">
                    <TextBlock Classes="label" Text="{l:Localize Budgets.Set.Title}" />
                    <Grid ColumnDefinitions="*,12,160,12,Auto" VerticalAlignment="Bottom">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{l:Localize Budgets.Category}" Classes="label" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                      DisplayMemberBinding="{Binding Name}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="{l:Localize Budgets.Limit}" Classes="label" />
                            <NumericUpDown Minimum="0"
                                           Increment="100"
                                           FormatString="N2"
                                           Value="{Binding NewLimit, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="4" Classes="accent"
                                Content="{l:Localize Budgets.Save}"
                                VerticalAlignment="Bottom"
                                IsEnabled="{Binding !IsLoading}"
                                Command="{Binding AddBudgetCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Coffer.Neg}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Budgets.Empty}" Classes="muted"
                       TextWrapping="Wrap" IsVisible="{Binding IsEmpty}" />

            <!-- Tracked budgets -->
            <Border Classes="panel" IsVisible="{Binding HasBudgets}">
                <StackPanel Spacing="14">
                    <TextBlock Classes="label" Text="{l:Localize Budgets.Section.Tracked}" />
                    <ItemsControl Name="BudgetsList" ItemsSource="{Binding Budgets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Coffer.Bd}" BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12" Margin="0,0,0,12">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource Coffer.Tx}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,2" Margin="0,0,8,0"
                                                    Background="{Binding ZoneColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
                                                <TextBlock Text="{Binding ZoneLabel}" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold" />
                                            </Border>
                                            <Button Grid.Column="2" Classes="chip" Content="{l:Localize Budgets.Remove}"
                                                    Command="{Binding DataContext.RemoveBudgetCommand, ElementName=BudgetsList}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                        <ProgressBar Classes="bar" Minimum="0" Maximum="100"
                                                     Value="{Binding BarValue}"
                                                     Foreground="{Binding ZoneColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                        <Grid ColumnDefinitions="*,*,*,*">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Budgets.Spent}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding SpentText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Budgets.Limit}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding LimitText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Budgets.Remaining}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding RemainingText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Spacing="2">
                                                <TextBlock Classes="label" Text="{l:Localize Budgets.Projected}" />
                                                <TextBlock Classes="money" FontSize="14" Text="{Binding ProjectedText}"
                                                           Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Unbudgeted this month -->
            <Border Classes="panel" IsVisible="{Binding HasUnbudgeted}">
                <StackPanel Spacing="10">
                    <TextBlock Classes="label" Text="{l:Localize Budgets.Section.Unbudgeted}" />
                    <ItemsControl ItemsSource="{Binding Unbudgeted}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,120" Margin="0,4">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource Coffer.Tx}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding SpentText}" Classes="money"
                                               HorizontalAlignment="Right"
                                               Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
