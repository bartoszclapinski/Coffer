<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Coffer.Desktop.Views"
        x:Class="Coffer.Desktop.Views.TransactionsPreviewWindow"
        x:CompileBindings="False"
        Title="Coffer — Transactions Preview"
        Width="1080" Height="760"
        Background="{DynamicResource Coffer.Bg}"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="22,14" HorizontalAlignment="Right">
            <Button Classes="chip" Content="Toggle theme" Click="OnToggleTheme" />
            <Button Classes="chip" Content="Toggle blur" Click="OnToggleBlur" />
        </StackPanel>
        <views:TransactionsView Grid.Row="1" Name="Section" />
    </Grid>
</Window>
