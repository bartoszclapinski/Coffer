<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Goals;assembly=Coffer.Application"
             xmlns:conv="clr-namespace:Coffer.Desktop.Converters"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.GoalsView"
             x:DataType="vm:GoalsViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="Border.badge">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.badgeText">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="360,*">
        <!-- Left: list + new-goal form -->
        <ScrollViewer Grid.Column="0">
            <StackPanel Margin="22,22,16,22" Spacing="16">
                <ProgressBar IsIndeterminate="True" Height="4"
                             IsVisible="{Binding IsLoading}" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Coffer.Neg}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <TextBlock Text="{l:Localize Goals.Empty}"
                           Classes="muted"
                           TextWrapping="Wrap"
                           IsVisible="{Binding IsEmpty}" />

                <ListBox ItemsSource="{Binding Goals}"
                         SelectedItem="{Binding SelectedGoal}"
                         Background="Transparent"
                         BorderThickness="0"
                         IsVisible="{Binding HasGoals}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:GoalDetailViewModel">
                            <Border Classes="panel" Margin="0,0,0,8">
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Coffer.Tx}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1" Classes="badge"
                                                Background="{Binding StatusColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
                                            <TextBlock Classes="badgeText" Text="{Binding StatusText}" />
                                        </Border>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Classes="muted" Text="{Binding TargetText}" />
                                        <TextBlock Classes="muted" Text="{Binding ProjectedDateText}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="label" Text="{l:Localize Goals.New.Title}" />
                        <TextBox Watermark="{l:Localize Goals.New.NameWatermark}"
                                 Text="{Binding NewGoalName}" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding GoalTypeOptions}"
                                  SelectedItem="{Binding NewGoalType}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:GoalTypeOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <NumericUpDown Watermark="{l:Localize Goals.New.TargetAmountWatermark}"
                                       Minimum="0"
                                       Increment="100"
                                       FormatString="N2"
                                       Value="{Binding NewGoalTargetAmount}" />
                        <DatePicker SelectedDate="{Binding NewGoalTargetDate}" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding PriorityOptions}"
                                  SelectedItem="{Binding NewGoalPriority}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PriorityOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="{l:Localize Goals.New.Submit}"
                                Classes="accent"
                                HorizontalAlignment="Stretch"
                                Command="{Binding CreateGoalCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Right: advisor suggestions + detail panel -->
        <ScrollViewer Grid.Column="1">
          <StackPanel>
            <Border Classes="panel" Margin="16,22,22,0"
                    IsVisible="{Binding HasSuggestions}">
                <StackPanel Spacing="12">
                    <TextBlock Classes="label" Margin="0"
                               Text="{l:Localize Goals.Suggestions.Title}" />
                    <TextBlock Text="{l:Localize Goals.Suggestions.EngineOnly}"
                               Classes="muted"
                               TextWrapping="Wrap"
                               IsVisible="{Binding SuggestionsAreEngineOnly}" />
                    <ItemsControl ItemsSource="{Binding Suggestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AdvisorSuggestionViewModel">
                                <Border Background="{DynamicResource Coffer.Hover}" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Coffer.Tx}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SavingsText}"
                                                       Foreground="{DynamicResource Coffer.Pos}"
                                                       FontWeight="SemiBold"
                                                       Margin="12,0,0,0"
                                                       IsVisible="{Binding HasSavings}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource Coffer.Mut}"
                                                   TextWrapping="Wrap" />
                                        <Border Classes="badge" HorizontalAlignment="Left"
                                                Background="{DynamicResource Coffer.Bd}"
                                                IsVisible="{Binding HasCategory}">
                                            <TextBlock Text="{Binding CategoryText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource Coffer.Tx}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ContentControl Content="{Binding SelectedGoal}"
                            IsVisible="{Binding SelectedGoal, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:GoalDetailViewModel">
                        <StackPanel Margin="16,22,22,22" Spacing="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Coffer.Tx}" />
                                    <TextBlock Text="{Binding TypeText}" Foreground="{DynamicResource Coffer.Mut}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="chip"
                                        Content="{l:Localize Goal.Archive}"
                                        VerticalAlignment="Center"
                                        IsEnabled="{Binding !IsBusy}"
                                        Command="{Binding ArchiveCommand}" />
                            </Grid>

                            <Border Classes="panel">
                                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Target}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding TargetText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Saved}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding SavedText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Remaining}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding RemainingText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="3" Spacing="2">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Confidence}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding ConfidenceText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,12,0,0">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Deadline}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding TargetDateText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,12,0,0">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Projection}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding ProjectedDateText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2" Margin="0,12,0,0">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.Required}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding RequiredMonthlyText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="3" Spacing="2" Margin="0,12,0,0">
                                        <TextBlock Classes="muted" Text="{l:Localize Goal.Metric.CurrentPace}" />
                                        <TextBlock Classes="money" FontSize="14" Text="{Binding CurrentMonthlyText}"
                                                   Classes.hidden="{Binding $parent[Window].DataContext.HideBalances}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Classes="panel">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="label" Text="{l:Localize Goal.Simulator.Title}" />
                                    <Slider Minimum="0" Maximum="10000"
                                            TickFrequency="100"
                                            Value="{Binding MonthlySavingInput}" />
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <NumericUpDown Grid.Column="0"
                                                       Minimum="0"
                                                       Increment="50"
                                                       FormatString="N2"
                                                       Width="160"
                                                       Value="{Binding MonthlySavingInput}" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12"
                                                    VerticalAlignment="Center">
                                            <TextBlock Classes="muted" Text="{l:Localize Goal.Simulator.ProjectionLabel}" VerticalAlignment="Center" />
                                            <TextBlock Classes="money" FontSize="14" Text="{Binding SimulatedProjectedDateText}"
                                                       VerticalAlignment="Center" />
                                            <Border Classes="badge"
                                                    Background="{Binding SimulatedStatusColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
                                                <TextBlock Classes="badgeText" Text="{Binding SimulatedStatusText}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <lvc:CartesianChart Height="220"
                                                        Series="{Binding ProjectionSeries}"
                                                        XAxes="{Binding ProjectionXAxes}" />
                                </StackPanel>
                            </Border>

                            <Border Classes="panel">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="label" Text="{l:Localize Goal.Scenarios.Title}" />
                                    <ItemsControl ItemsSource="{Binding Scenarios}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:GoalScenarioViewModel">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               Foreground="{DynamicResource Coffer.Tx}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Classes="muted"
                                                               Text="{Binding MonthlySavingText}"
                                                               Margin="12,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                               Text="{Binding ProjectedDateText}"
                                                               Margin="12,0" VerticalAlignment="Center" />
                                                    <Border Grid.Column="3" Classes="badge" Margin="12,0,0,0"
                                                            Background="{Binding StatusColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
                                                        <TextBlock Classes="badgeText" Text="{Binding StatusText}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="panel" IsVisible="{Binding HasRisks}">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="label" Text="{l:Localize Goal.Risks.Title}" />
                                    <ItemsControl ItemsSource="{Binding Risks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource Coffer.Mut}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="panel">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="label" Text="{l:Localize Goal.Contribution.Title}" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <NumericUpDown Grid.Column="0"
                                                       Minimum="0"
                                                       Increment="50"
                                                       FormatString="N2"
                                                       Watermark="{l:Localize Goal.Contribution.AmountWatermark}"
                                                       Value="{Binding ContributionAmount}" />
                                        <Button Grid.Column="1"
                                                Classes="accent"
                                                Content="{l:Localize Goal.Contribution.Submit}"
                                                Margin="12,0,0,0"
                                                IsEnabled="{Binding !IsBusy}"
                                                Command="{Binding AddContributionCommand}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
          </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
