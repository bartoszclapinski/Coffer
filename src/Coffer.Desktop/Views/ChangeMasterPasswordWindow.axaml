<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Security;assembly=Coffer.Application"
        xmlns:l="clr-namespace:Coffer.Desktop.Localization"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="440"
        x:Class="Coffer.Desktop.Views.ChangeMasterPasswordWindow"
        x:DataType="vm:ChangeMasterPasswordViewModel"
        x:CompileBindings="False"
        Title="{l:Localize ChangePassword.Title}"
        Width="460" Height="440"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28">
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="{l:Localize ChangePassword.Title}" FontSize="20" FontWeight="Light" />
            <TextBlock Text="{l:Localize ChangePassword.Intro}" TextWrapping="Wrap" Foreground="#8E8E93" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="12" Margin="0,20,0,0" VerticalAlignment="Top">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize ChangePassword.Current}" />
                <TextBox PasswordChar="●" IsEnabled="{Binding !IsBusy}"
                         Text="{Binding CurrentPassword, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize ChangePassword.New}" />
                <TextBox PasswordChar="●" IsEnabled="{Binding !IsBusy}"
                         Text="{Binding NewPassword, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize ChangePassword.Confirm}" />
                <TextBox PasswordChar="●" IsEnabled="{Binding !IsBusy}"
                         Text="{Binding ConfirmPassword, Mode=TwoWay}" />
            </StackPanel>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#D14" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsBusy}" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{l:Localize ChangePassword.Note}"
                   FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap" Margin="0,8,0,0" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,16,0,0">
            <Button Content="{l:Localize ChangePassword.Cancel}" MinWidth="100" IsCancel="True"
                    Command="{Binding CancelCommand}" />
            <Button Content="{l:Localize ChangePassword.Submit}" MinWidth="140" IsDefault="True"
                    IsEnabled="{Binding !IsBusy}" Command="{Binding ChangeCommand}" />
        </StackPanel>
    </Grid>
</Window>
