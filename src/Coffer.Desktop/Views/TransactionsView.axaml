<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Coffer.Application.ViewModels.Transactions;assembly=Coffer.Application"
             xmlns:conv="clr-namespace:Coffer.Desktop.Converters"
             xmlns:l="clr-namespace:Coffer.Desktop.Localization"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
             x:Class="Coffer.Desktop.Views.TransactionsView"
             x:DataType="vm:TransactionsViewModel"
             x:CompileBindings="False">
    <Grid Margin="40,32" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{l:Localize Transactions.Title}"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="#1D1D1F" />
                <TextBlock Text="{l:Localize Transactions.Subtitle}"
                           Foreground="#8E8E93" />
            </StackPanel>
            <Button Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="{l:Localize Transactions.Recategorize}"
                    Command="{Binding RecategorizeExistingCommand}" />
        </Grid>

        <!-- Filter bar -->
        <Grid Grid.Row="1" Margin="0,20,0,0" ColumnDefinitions="*,12,170,12,170,12,150">
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="{l:Localize Transactions.SearchWatermark}" />
            <ComboBox Grid.Column="2"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="{l:Localize Transactions.Filter.AllAccounts}"
                      ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name, Converter={x:Static conv:LocalizeKeyConverter.Instance}}" />
                            <TextBlock Text="{Binding BankCode}" Foreground="#8E8E93" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox Grid.Column="4"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="{l:Localize Transactions.Filter.AllCategories}"
                      ItemsSource="{Binding CategoryFilters}"
                      SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                            <TextBlock Text="{Binding Name, Converter={x:Static conv:LocalizeKeyConverter.Instance}}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox Grid.Column="6"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding DateRanges}"
                      SelectedItem="{Binding SelectedRange, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding LabelKey, Converter={x:Static conv:LocalizeKeyConverter.Instance}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Panel Grid.Row="2" Margin="0,20,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         VerticalAlignment="Top"
                         IsVisible="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#D14"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{l:Localize Transactions.Empty}"
                       Foreground="#8E8E93"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsEmpty}" />

            <DataGrid ItemsSource="{Binding Transactions}"
                      IsVisible="{Binding !IsEmpty}"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="#FFFFFF"
                      BorderBrush="#E5E5EA"
                      BorderThickness="1"
                      CornerRadius="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{l:Localize Transactions.Column.Date}"
                                        Binding="{Binding Date, StringFormat=\{0:yyyy-MM-dd\}}"
                                        Width="110" />
                    <DataGridTextColumn Header="{l:Localize Transactions.Column.Description}"
                                        Binding="{Binding Description}"
                                        Width="2*" />
                    <DataGridTextColumn Header="{l:Localize Transactions.Column.Merchant}"
                                        Binding="{Binding Merchant}"
                                        Width="*" />
                    <DataGridTextColumn Header="{l:Localize Transactions.Column.Account}"
                                        Binding="{Binding AccountName}"
                                        Width="*" />
                    <DataGridTemplateColumn Header="{l:Localize Transactions.Column.Category}" Width="1.6*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" Margin="6,0">
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}"
                                             Fill="{Binding SelectedCategory.Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                    <ComboBox Grid.Column="1"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="{l:Localize Transactions.Uncategorized}"
                                              ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                                             Fill="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                                                    <TextBlock Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{l:Localize Transactions.Column.Amount}" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Amount, Converter={x:Static conv:AmountToBrushConverter.Instance}}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:N2} {1}">
                                            <Binding Path="Amount" />
                                            <Binding Path="Currency" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Panel>
    </Grid>
</UserControl>
